# AI API Keys (Get these from respective platforms)
XAI_API_KEY=your-xai-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGING_FACE_API_TOKEN=your-huggingface-token-here
REPLICATE_API_TOKEN=your-replicate-api-token-here
SUNO_API_KEY=your-suno-api-key-here
XAI_TIMEOUT_MS=28000
MUSICGEN_URL=http://localhost:5005/generate
MUSICGEN_SIDECAR_URL=http://localhost:8001
SAMPLE_LIBRARY_PATH=

# Local AI (Ollama) — used by Astutely and Organism for beat/vibe generation
# For Railway: OLLAMA_BASE_URL=http://ollama.railway.internal:PORT
# Railway volume must be >= 4GB to persist llama3.2:3b (2GB) across deploys
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
VITE_STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID_PRO=your-stripe-price-id
STRIPE_PRICE_ID_PRO_MEMBERSHIP=your-stripe-pro-membership-price-id
STRIPE_PRICE_ID_STUDIO=your-stripe-studio-price-id
STRIPE_PRICE_ID_CREATOR=your-stripe-creator-price-id
STRIPE_PRICE_ID_100_CREDITS=your-stripe-100-credits-price-id
STRIPE_PRICE_ID_500_CREDITS=your-stripe-500-credits-price-id
STRIPE_PRICE_ID_1000_CREDITS=your-stripe-1000-credits-price-id
STRIPE_PRICE_ID_5000_CREDITS=your-stripe-5000-credits-price-id

# Billing & Session
# Generate each secret with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=your-secret-session-key-here
AUTH_TOKEN_SECRET=your-jwt-signing-secret-here
APP_URL=http://localhost:5000
PORT=5000
CI=false

# Owner Access
# OWNER_KEY MUST be at least 32 characters — the auth middleware rejects shorter
# keys as a safety floor. Use the same node -e crypto.randomBytes command above.
# NEVER prefix this with VITE_ — that would ship the admin key into the browser bundle.
OWNER_KEY=your-owner-key-min-32-chars
OWNER_EMAIL=owner@example.com

# Google Analytics
VITE_GA_MEASUREMENT_ID=your-ga-measurement-id

# Optional Database (Neon/Postgres)
DATABASE_URL=postgresql://username:password@host:port/database
LOCAL_OBJECTS_DIR=./objects
PRIVATE_OBJECT_DIR=
MCP_HANDOFF_PATH=
DATA_ROOT=./data

# Optional local dev embedding
EMBED_VITE=false

# Optional client feature flags (set to true/false as needed)
# Voice Conversion Pipeline
RVC_API_URL=http://localhost:7870
# For Railway: AUDIO_ANALYSIS_API_URL=http://audio-analysis.railway.internal:7871
AUDIO_ANALYSIS_API_URL=http://localhost:7871
APP_BASE_URL=http://localhost:4000
API_KEY_ENCRYPTION_SECRET=change-me-to-a-random-32-char-string-minimum

# WebEar Audio Debug Bridge
VITE_WEBEAR_API_KEY=your-webear-api-key

VITE_USE_NEW_HERO=false
VITE_USE_V2_DESIGN=false
VITE_USE_NEW_NAVIGATION=false
VITE_USE_NEW_STUDIO_DASHBOARD=false
VITE_USE_NEW_PIANO_ROLL=false
VITE_USE_NEW_BEAT_MAKER=false
VITE_USE_NEW_AI_COPILOT=false
VITE_USE_NEW_SOCIAL_HUB=false
VITE_ENABLE_PARTICLE_EFFECTS=false
VITE_ENABLE_AUDIO_REACTIVE=false
VITE_ENABLE_SOUND_EFFECTS=false
VITE_ENABLE_GLASSMORPHISM=false
