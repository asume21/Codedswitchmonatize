# Dockerfile.ollama
# Docker container with CodedSwitch + Ollama + Phi3 for Railway deployment

FROM node:20-bullseye

ARG OLLAMA_MODEL=llama3.1:8b

# Install Ollama dependencies (including zstd required by Ollama installer)
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    zstd \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama and pull model (start server temporarily for pull)
RUN curl -fsSL https://ollama.com/install.sh | sh \
  && (OLLAMA_HOST=127.0.0.1:11434 ollama serve >/tmp/ollama.log 2>&1 &) \
  && sleep 8 \
  && OLLAMA_HOST=127.0.0.1:11434 ollama pull ${OLLAMA_MODEL} \
  && pkill ollama || true

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json npm-shrinkwrap.json ./

# Install Node dependencies
RUN npm install --omit=dev

# Copy application code
COPY . .

# Build TypeScript
RUN npm run build

# Expose ports
EXPOSE 5000

# Startup script
COPY docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh
RUN sed -i 's/\r$//' /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/bin/bash", "/usr/local/bin/docker-entrypoint.sh"]
