# Dockerfile.ollama
# Standalone Ollama service for the Railway "ollama" service.
# Overrides the default entrypoint so the model is pulled once on first boot
# and persisted on the Railway volume at /root/.ollama.
#
# NOTE: In Railway Settings → Source → Watch Paths, set this to "Dockerfile.ollama"
# so that normal code pushes do NOT trigger an Ollama redeploy.

FROM ollama/ollama

# Install curl for the health-check loop (not present in the base image)
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Override the default /bin/ollama entrypoint with bash so we can run a script
ENTRYPOINT ["/bin/bash", "-c"]

# 1. Start Ollama server in background
# 2. Poll until the REST API responds (server ready)
# 3. Pull the model only if it isn't already on the volume
# 4. Keep the server running as PID 1 (wait)
CMD ["ollama serve & SERVER_PID=$!; \
      echo '[ollama-init] Waiting for server...'; \
      until curl -sf http://localhost:11434/api/tags > /dev/null 2>&1; do sleep 2; done; \
      echo '[ollama-init] Server ready.'; \
      if ollama list 2>/dev/null | grep -q 'codellama:7b'; then \
        echo '[ollama-init] codellama:7b already on volume — skipping pull.'; \
      else \
        echo '[ollama-init] Pulling codellama:7b (~3.8 GB, one-time)...'; \
        ollama pull codellama:7b; \
        echo '[ollama-init] Pull complete.'; \
      fi; \
      wait $SERVER_PID"]
